class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int n = s.size();
        if (n == 0)
            return 0;
        int maxLen = 1;

        for (int i = 0; i < n; i++) {
            vector<bool> seen(128,false);
            for (int j = i; j < n; j++) {
                if(seen[char(s[j])] == true) break;
                if(j - i + 1 > maxLen) maxLen = j - i + 1;
                seen[char(s[j])] = true;
            }
        }

        return maxLen;
    }
};
